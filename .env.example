MINERU_POLL_TIMEOUT=300

# ============================================
# LlamaIndex 文档切块配置
# ============================================
# 切块策略: sentence / semantic / fixed
LLAMAINDEX_CHUNK_STRATEGY=semantic
# 单块大小（字符或 token）
LLAMAINDEX_CHUNK_SIZE=1000
# 块之间的重叠
LLAMAINDEX_CHUNK_OVERLAP=200
# SentenceSplitter 块大小
LLAMAINDEX_SENTENCE_CHUNK_SIZE=1024
# SentenceSplitter 重叠
LLAMAINDEX_SENTENCE_CHUNK_OVERLAP=200
# 语义切分缓冲区大小
LLAMAINDEX_SEMANTIC_BUFFER_SIZE=1
# 语义切分阈值
LLAMAINDEX_SEMANTIC_THRESHOLD=0.5
# 默认分词分隔符
LLAMAINDEX_SEPARATOR=" "
# 段落分隔符
LLAMAINDEX_PARAGRAPH_SEPARATOR="\n\n"
# 是否在节点元数据中包含原始信息
LLAMAINDEX_INCLUDE_METADATA=true
# 是否包含前后邻接节点关系
LLAMAINDEX_INCLUDE_PREV_NEXT=true
# LlamaIndex 索引存储目录
LLAMAINDEX_STORAGE_DIR=resources/storage/hierarchical
# 建议：若希望利用章节/块层次结构提升召回精度，需配合下方 SYSTEM__HYBRID_RETRIEVAL_ENABLED=true。
# LightRAG/摘要默认语言
SUMMARY_LANGUAGE=zh-CN

# ============================================
# Reranker 配置
# ============================================
# 重排后端：dashscope / xinference / llamaindex
RERANKER_BACKEND=dashscope
# 重排模型名称
RERANKER_MODEL=gte-rerank-v2
# DashScope 重排 API Key
DASHSCOPE_API_KEY=sk-5c2c6bb5599441f49833ad208a717f1f
# DashScope 重排模型名称
DASHSCOPE_RERANK_MODEL=gte-rerank-v2
# 重排服务的 HTTP 地址
RERANKER_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
# 重排返回的候选数
RERANKER_TOP_N=5
# 重排请求超时时间（秒）
RERANKER_TIMEOUT=30
# 是否返回重排后的原文
RERANKER_RETURN_DOCUMENTS=false
# 是否对分数做归一化
RERANKER_NORMALIZE_SCORES=false
# 是否启用 LlamaIndex 重排
LLAMA_INDEX_RERANK_ENABLED=true
# LlamaIndex 初步召回数量
SIMILARITY_TOP_K=50
# LlamaIndex 最终保留数量
RERANK_TOP_K=5
# 重排策略（replace / blend）
RERANKER_STRATEGY=replace
# 重排分数权重
RERANK_WEIGHT=0.7
# 向量相似度权重
FAISS_WEIGHT=0.3
# 注意：
# - 当 SYSTEM__HYBRID_RETRIEVAL_ENABLED=false 时，仅使用 Milvus 向量召回；建议保留 KB_RERANK_ENABLED=true 以提升精度。
# - 当 SYSTEM__HYBRID_RETRIEVAL_ENABLED=true 时，LlamaIndex + Milvus 双路并行，LLAMA_INDEX_RERANK_ENABLED 与 KB_RERANK_ENABLED 可同时打开。
# - KB_RERANK_ENABLED 依赖上面 Reranker 配置；请确保模型/API Key 可用，否则召回会回退到未重排结果。

# ============================================
# 知识库 / RAG 控制
# ============================================
# 是否启用 LlamaIndex + Milvus 混合检索（false 只用 Milvus）
SYSTEM__HYBRID_RETRIEVAL_ENABLED=false
# 是否对知识库 Top-K 结果做重排
KB_RERANK_ENABLED=true
# 是否以纯文本输出答案（去掉 Markdown 符号，供前端直接展示）
ANSWER__PLAIN_OUTPUT=false
# 知识库回答时每篇文档截取的最大上下文长度（字符数），调小可减少 LLM 负载
KNOWLEDGE_MAX_CONTEXT_PER_DOC=6000
# LightRAG 工作目录（图谱检索存放路径）
LIGHTRAG_WORKDIR=resources/data/lightrag
# LightRAG 检索模式（naive/local/global/hybrid）
LIGHTRAG_QUERY_MODE=hybrid
# Text2SQL 查询分析缓存上限（条）
TEXT2SQL_QUERY_CACHE_SIZE=256
# 是否允许 Text2SQL 使用 UNION/UNION ALL 查询
TEXT2SQL__ALLOW_UNION=true

# ============================================
# AgentChat / 对话编排配置
# ============================================
# 是否启用 AgentChat Team（UserProxy + Router Assistant）
AGENTCHAT_TEAM_ENABLED=true
# 是否启用 AgentChat 单 Assistant Router（工具兜底）
AGENTCHAT_ENABLED=true
# AgentChat 失败时是否直接报错（true 不再回退传统路由）
AGENTCHAT_NO_FALLBACK=false
# AgentChat 是否输出流式内容（SSE chunk）
AGENTCHAT_STREAM_ENABLED=false
# AgentChat 是否在工具调用后做反思总结（true 更强，false 更快）
AGENTCHAT_REFLECT=true
# 单次对话允许的工具迭代次数（>=1，越大越慢）
AGENTCHAT_MAX_TOOL_ITERATIONS=2

# ============================================
# AgentChat / 会话记忆配置
# ============================================
# 单个会话记忆中保留的最大消息条数
MEMORY_MAX_ITEMS=50
# 每条记忆内容的最大字符数，超出会截断
MEMORY_TRUNCATE_CHARS=800
# AgentChat 记忆持久化 Redis 地址（留空则仅用进程内存）
AGENTCHAT_REDIS_URL=
# Redis 中的命名空间前缀
AGENTCHAT_REDIS_NAMESPACE=agentchat_memory
# Redis 记忆 TTL（秒，为 0 表示不过期）
AGENTCHAT_REDIS_TTL_SECONDS=0
# 建议：
# 1) 若只需纯向量检索，可将 SYSTEM__HYBRID_RETRIEVAL_ENABLED 设为 false；
# 2) 若需要章节/块信息，设为 true 并保证 LLAMAINDEX_* 配置有效；
# 3) LightRAG 依赖 lightrag-hku 包和可用的 embedding backend（dashscope/openai）。

