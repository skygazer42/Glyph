# ============================================
# LLM 配置
# ============================================
# LLM 主 API Key（用于 model_client 调度）
LLM_API_KEY=sk-5c2c6bb5599441f49833ad208a717f1f
# OpenAI 兼容的推理服务地址
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 默认使用的对话模型名称
LLM_MODEL_NAME=deepseek-v3.2-exp
# LLM 解码温度（0 表示更确定的回答）
LLM_TEMPERATURE=0
# AgentService 保存上下文的轮次缓存
LLM_CTX_BUFFER_SIZE=10

# ============================================
# Vision / Multimodal 模型
# ============================================
# 是否启用多模态视觉模型
VISION__ENABLED=True
# 视觉模型名称
VISION__MODEL=qwen3-vl-flash
# 视觉模型 API Key（未显式传入时回退到全局 LLM_API_KEY）
VISION__API_KEY=sk-5c2c6bb5599441f49833ad208a717f1f
# 视觉模型请求地址
VISION__BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 视觉模型系统提示模板
VISION__PROMPT_TEMPLATE=请关注图片中的地点、票据、票面文字等与政策或优惠相关的要素，并返回结构化描述。
# 单次允许解析的最大图片数量
VISION__MAX_IMAGES=2
# 视觉模型最大输出 token 数
VISION__MAX_OUTPUT_TOKENS=800
# 提供给外部工具的备用视觉 API Key
VISION_API_KEY=sk-5c2c6bb5599441f49833ad208a717f1f

# ============================================
# 用户档案 / 历史查询 数据源
# ============================================
# Mock 用户历史信息所在的 JSON 文件路径
USER_PROFILE_DB_PATH=resources/data/user_profiles.json

# ============================================
# Web Search 联网兜底
# ============================================
# 是否允许使用联网搜索工具
WEB_SEARCH__ENABLED=True
# 联网搜索提供商（tavily / bing / ...）
WEB_SEARCH__PROVIDER=tavily
# Tavily API Key
WEB_SEARCH__TAVILY_API_KEY=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
# 搜索深度（basic / advanced）
WEB_SEARCH__SEARCH_DEPTH=basic
# 每次返回的最大结果条数
WEB_SEARCH__MAX_RESULTS=3
# 限定搜索域名（会自动拼接 site:）
WEB_SEARCH__SITE_FILTER=http://www.jinan.gov.cn/index.html
# 兜底用的 Tavily API Key（当嵌套配置未设置时使用）
TAVILY_API_KEY=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

# ============================================
# Embedding 配置
# ============================================
# 向量生成后端（openai 或 dashscope 等）
EMBEDDING_BACKEND=dashscope
# OpenAI Embedding API Key
EMBEDDING_OPENAI_API_KEY=
# OpenAI Embedding Base URL
EMBEDDING_OPENAI_BASE_URL=
# OpenAI Embedding 模型名称
EMBEDDING_OPENAI_MODEL=text-embedding-3-small
# DashScope Embedding API Key
EMBEDDING_DASHSCOPE_API_KEY=sk-5c2c6bb5599441f49833ad208a717f1f
# DashScope Embedding 模型
EMBEDDING_DASHSCOPE_MODEL=text-embedding-v3
# 向量维度
EMBEDDING_DIM=1024
# 嵌入批量大小
EMBEDDING_BATCH_SIZE=32
# 嵌入请求超时时间（秒）
EMBEDDING_TIMEOUT=30

# ============================================
# MinerU 2.5 文档解析
# ============================================
# 是否启用 MinerU 解析服务
MINERU_ENABLED=false
# MinerU API 基础地址
MINERU_API_BASE_URL=http://localhost:8080
# MinerU API Key
MINERU_API_KEY=
# MinerU API 请求超时时间（秒）
MINERU_TIMEOUT=300
# 是否提取图片
MINERU_EXTRACT_IMAGES=true
# 是否提取表格
MINERU_EXTRACT_TABLES=true
# 是否提取列表
MINERU_EXTRACT_LISTS=true
# 是否提取公式
MINERU_EXTRACT_FORMULAS=true
# 是否保留原始版式
MINERU_PRESERVE_LAYOUT=true
# 是否对全部图片进行 OCR
MINERU_OCR_ALL_IMAGES=true
# OCR 分辨率（DPI）
MINERU_OCR_DPI=300
# 输出格式（markdown / text 等）
MINERU_OUTPUT_FORMAT=markdown
# 是否同时返回原始 OCR
MINERU_INCLUDE_RAW_OCR=true

# ============================================
# LlamaIndex 文档切块配置
# ============================================
# 切块策略: sentence / semantic / fixed
LLAMAINDEX_CHUNK_STRATEGY=semantic
# 单块大小（字符或 token）
LLAMAINDEX_CHUNK_SIZE=1000
# 块之间的重叠
LLAMAINDEX_CHUNK_OVERLAP=200
# SentenceSplitter 块大小
LLAMAINDEX_SENTENCE_CHUNK_SIZE=1024
# SentenceSplitter 重叠
LLAMAINDEX_SENTENCE_CHUNK_OVERLAP=200
# 语义切分缓冲区大小
LLAMAINDEX_SEMANTIC_BUFFER_SIZE=1
# 语义切分阈值
LLAMAINDEX_SEMANTIC_THRESHOLD=0.5
# 默认分词分隔符
LLAMAINDEX_SEPARATOR=" "
# 段落分隔符
LLAMAINDEX_PARAGRAPH_SEPARATOR="\n\n"
# 是否在节点元数据中包含原始信息
LLAMAINDEX_INCLUDE_METADATA=true
# 是否包含前后邻接节点关系
LLAMAINDEX_INCLUDE_PREV_NEXT=true

# ============================================
# Reranker 配置
# ============================================
# 重排后端：dashscope / xinference / llamaindex
RERANKER_BACKEND=dashscope
# 重排模型名称
RERANKER_MODEL=gte-rerank-v2
# DashScope 重排 API Key
DASHSCOPE_API_KEY=sk-5c2c6bb5599441f49833ad208a717f1f
# DashScope 重排模型名称
DASHSCOPE_RERANK_MODEL=gte-rerank-v2
# 重排服务的 HTTP 地址
RERANKER_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
# 重排返回的候选数
RERANKER_TOP_N=5
# 重排请求超时时间（秒）
RERANKER_TIMEOUT=30
# 是否返回重排后的原文
RERANKER_RETURN_DOCUMENTS=false
# 是否对分数做归一化
RERANKER_NORMALIZE_SCORES=false
# 是否启用 LlamaIndex 重排
LLAMA_INDEX_RERANK_ENABLED=true
# LlamaIndex 初步召回数量
SIMILARITY_TOP_K=50
# LlamaIndex 最终保留数量
RERANK_TOP_K=5
# 知识库链路是否使用重排
KB_RERANK_ENABLED=true
# 重排策略（replace / blend）
RERANKER_STRATEGY=replace
# 重排分数权重
RERANK_WEIGHT=0.7
# 向量相似度权重
FAISS_WEIGHT=0.3

# ============================================
# 数据库配置
# ============================================
# Neo4j Bolt URL
DATABASE__NEO4J_URI=bolt://localhost:7687
# Neo4j 用户名
DATABASE__NEO4J_USER=neo4j
# Neo4j 密码
DATABASE__NEO4J_PASSWORD=kdsoft2025
# 是否启用 Neo4j
DATABASE__USE_NEO4J=false
# MySQL 主机地址
DATABASE__MYSQL_HOST=localhost
# MySQL 端口
DATABASE__MYSQL_PORT=3307
# MySQL 用户名
DATABASE__MYSQL_USER=glyph
# MySQL 密码
DATABASE__MYSQL_PASSWORD=glyph
# MySQL 数据库名
DATABASE__MYSQL_DB=policy_db
# Milvus 服务地址
DATABASE__MILVUS_HOST=localhost
# Milvus 服务端口
DATABASE__MILVUS_PORT=19530
# Milvus 用户名
DATABASE__MILVUS_USER=
# Milvus 密码
DATABASE__MILVUS_PASSWORD=
# Milvus 数据库名称
DATABASE__MILVUS_DB_NAME=default
# Milvus Collection 名称
DATABASE__MILVUS_COLLECTION_NAME=policy_documents
# 是否启用 Milvus TLS 连接
DATABASE__MILVUS_USE_SECURE=false

# ============================================
# API 安全配置
# ============================================
# JWT 签名 Secret
SECURITY__JWT_SECRET=dev-secret-key
# JWT 算法
SECURITY__JWT_ALGORITHM=HS256
# JWT 过期时间（分钟）
SECURITY__JWT_EXP_MINUTES=60
# 默认 API 用户名
SECURITY__API_DEFAULT_USERNAME=admin
# 默认 API 密码
SECURITY__API_DEFAULT_PASSWORD=admin123
# 默认 API 用户显示名
SECURITY__API_DEFAULT_FULLNAME=Administrator
# /query 每窗口允许的次数
SECURITY__RATE_LIMIT_QUERY_TIMES=30
# /query 时间窗口（秒）
SECURITY__RATE_LIMIT_QUERY_SECONDS=60
# /load-docs 每窗口允许的次数
SECURITY__RATE_LIMIT_DOCS_TIMES=5
# /load-docs 时间窗口（秒）
SECURITY__RATE_LIMIT_DOCS_SECONDS=60
# 速率限制使用的 Redis URL
SECURITY__RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
# 是否禁用认证（仅测试）
SECURITY__DISABLE_AUTH=false

# ============================================
# 文档处理配置
# ============================================
# 允许上传的最大文件大小（MB）
DOCUMENT__MAX_FILE_SIZE_MB=50
# 单个文档允许的最大页数
DOCUMENT__MAX_PAGES=100

# ============================================
# 性能配置
# ============================================
# 同时处理的最大查询数
PERFORMANCE__MAX_CONCURRENT_QUERIES=5
# 单个查询超时时间（秒）
PERFORMANCE__QUERY_TIMEOUT=30
# 文档批量入库的批大小
PERFORMANCE__BATCH_SIZE=10
# 文档批处理超时时间（秒）
PERFORMANCE__BATCH_TIMEOUT=300
# 向量批处理大小
PERFORMANCE__EMBEDDING_BATCH_SIZE=32
# 向量检索超时时间（秒）
PERFORMANCE__VECTOR_SEARCH_TIMEOUT=10
# 是否启用缓存
PERFORMANCE__ENABLE_CACHE=true
# 缓存 TTL（秒）
PERFORMANCE__CACHE_TTL=3600

# ============================================
# 系统配置
# ============================================
# 是否开启 DEBUG 日志
DEBUG=false
# 是否输出更详细的日志
VERBOSE=false
# 是否启用 LlamaIndex + Milvus 混合检索
SYSTEM__HYBRID_RETRIEVAL_ENABLED=false
# LlamaIndex 存储目录
LLAMAINDEX_STORAGE_DIR=resources/storage/hierarchical

# ============================================
# 多轮对话配置
# ============================================
# 单次会话最大轮次
CONVERSATION__MAX_TURNS=20
# 回溯的历史窗口
CONVERSATION__HISTORY_WINDOW=5

# ============================================
# 并行/早停配置
# ============================================
# 置信度达到该阈值时提前停止
EARLY_STOP_CONF=0.80

# ============================================
# LightRAG 图谱检索配置
# ============================================
# LightRAG 工作目录
LIGHTRAG_WORKDIR=resources/data/lightrag

# ============================================
# 日志配置
# ============================================
# 日志目录（统一输出到 resources/logs）
LOG_DIR=resources/logs
# 单个日志文件最大字节
LOG_MAX_BYTES=10485760
# 保留的日志轮转数量
LOG_BACKUP_COUNT=5
# 是否输出更详细的调试日志
VERBOSE_DEBUG=false
