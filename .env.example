# ============================================
# LLM 配置
# ============================================
# 说明：LLM_BASE_URL 支持所有 OpenAI 兼容的 API（DeepSeek、OpenAI、本地部署等）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-chat
LLM_TEMPERATURE=0
LLM_CTX_BUFFER_SIZE=10

# ============================================
# Embedding 配置
# ============================================
# 后端选择: openai, dashscope
EMBEDDING_BACKEND=openai

# OpenAI Embedding
EMBEDDING_OPENAI_API_KEY=
EMBEDDING_OPENAI_BASE_URL=
EMBEDDING_OPENAI_MODEL=text-embedding-3-small

# DashScope Embedding
EMBEDDING_DASHSCOPE_API_KEY=
EMBEDDING_DASHSCOPE_MODEL=text-embedding-v2

# 通用 Embedding 配置
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT=30

# ============================================
# MinerU 2.5 文档解析
# ============================================
MINERU_ENABLED=false
MINERU_API_BASE_URL=http://localhost:8080
MINERU_API_KEY=
MINERU_TIMEOUT=300

# 文档解析选项
MINERU_EXTRACT_IMAGES=true
MINERU_EXTRACT_TABLES=true
MINERU_EXTRACT_LISTS=true
MINERU_EXTRACT_FORMULAS=true

# 处理选项
MINERU_PRESERVE_LAYOUT=true
MINERU_OCR_ALL_IMAGES=true
MINERU_OCR_DPI=300

# 输出格式
MINERU_OUTPUT_FORMAT=markdown
MINERU_INCLUDE_RAW_OCR=true

# ============================================
# LlamaIndex 文档切块配置
# ============================================
# 切块策略: sentence, semantic, fixed
LLAMAINDEX_CHUNK_STRATEGY=sentence

# 切块大小
LLAMAINDEX_CHUNK_SIZE=1000
LLAMAINDEX_CHUNK_OVERLAP=200

# Sentence Splitter 配置
LLAMAINDEX_SENTENCE_CHUNK_SIZE=1024
LLAMAINDEX_SENTENCE_CHUNK_OVERLAP=200

# Semantic Splitter 配置
LLAMAINDEX_SEMANTIC_BUFFER_SIZE=1
LLAMAINDEX_SEMANTIC_THRESHOLD=0.5

# 分隔符配置
LLAMAINDEX_SEPARATOR=" "
LLAMAINDEX_PARAGRAPH_SEPARATOR="\n\n"

# 其他选项
LLAMAINDEX_INCLUDE_METADATA=true
LLAMAINDEX_INCLUDE_PREV_NEXT=true

# ============================================
# Reranker 配置
# ============================================
# 后端选择: dashscope, xinference, llamaindex
RERANKER_BACKEND=dashscope
RERANKER_MODEL=gte-rerank-v2

# DashScope Reranker
DASHSCOPE_API_KEY=your_dashscope_key
DASHSCOPE_RERANK_MODEL=gte-rerank-v2
RERANKER_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank

# Reranker 参数
RERANKER_TOP_N=5
RERANKER_TIMEOUT=30
RERANKER_RETURN_DOCUMENTS=false
RERANKER_NORMALIZE_SCORES=false

# LlamaIndex Rerank 配置
LLAMA_INDEX_RERANK_ENABLED=true
SIMILARITY_TOP_K=50
RERANK_TOP_K=5

# Reranker 策略配置
KB_RERANK_ENABLED=true
RERANKER_STRATEGY=replace
RERANK_WEIGHT=0.7
FAISS_WEIGHT=0.3

# ============================================
# 数据库配置
# ============================================

# Neo4j 知识图谱
DATABASE__NEO4J_URI=bolt://localhost:7687
DATABASE__NEO4J_USER=neo4j
DATABASE__NEO4J_PASSWORD=password
DATABASE__USE_NEO4J=false

# Milvus 向量数据库（推荐用于生产环境）
DATABASE__MILVUS_HOST=localhost
DATABASE__MILVUS_PORT=19530
DATABASE__MILVUS_USER=
DATABASE__MILVUS_PASSWORD=
DATABASE__MILVUS_DB_NAME=default
DATABASE__MILVUS_COLLECTION_NAME=policy_documents
DATABASE__MILVUS_USE_SECURE=false

# ============================================
# 文档处理配置
# ============================================
# 文档限制
DOCUMENT__MAX_FILE_SIZE_MB=50
DOCUMENT__MAX_PAGES=100

# ============================================
# 性能配置
# ============================================
# 并发处理
PERFORMANCE__MAX_CONCURRENT_QUERIES=5
PERFORMANCE__QUERY_TIMEOUT=30

# 文档处理
PERFORMANCE__BATCH_SIZE=10
PERFORMANCE__BATCH_TIMEOUT=300

# 向量操作
PERFORMANCE__EMBEDDING_BATCH_SIZE=32
PERFORMANCE__VECTOR_SEARCH_TIMEOUT=10

# 缓存
PERFORMANCE__ENABLE_CACHE=true
PERFORMANCE__CACHE_TTL=3600

# ============================================
# 系统配置
# ============================================
DEBUG=false
VERBOSE=false

# ============================================
# 多轮对话配置
# ============================================
CONVERSATION__MAX_TURNS=20
CONVERSATION__HISTORY_WINDOW=5

# ============================================
# 并行/早停配置
# ============================================
EARLY_STOP_CONF=0.80

# ============================================
# LightRAG 图谱检索配置
# ============================================
LIGHTRAG_WORKDIR=resources/data/lightrag

# ============================================
# 日志配置
# ============================================
LOG_DIR=.
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
VERBOSE_DEBUG=false
